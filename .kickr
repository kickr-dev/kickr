# Kickr configuration file (https://github.com/kickr-dev/kickr)
# yaml-language-server: $schema=https://raw.githubusercontent.com/kickr-dev/kickr/beta/.schemas/kickr.v1.schema.json
version: 1
ci:
  provider: gitlab
  options:
    - kickr
  docker: {}
  release: {}
dependencies:
  manager: renovate
  local: configs/renovate/local.json
exclude:
  - shell
license: apache-2.0
maintainers:
  - name: kilianpaquier
platform: gitlab
pre-commit:
  - conventional-commits
  - gitflow-branches
