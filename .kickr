# Kickr configuration file (https://github.com/kickr-dev/kickr)
# yaml-language-server: $schema=https://raw.githubusercontent.com/kickr-dev/kickr/beta/.schemas/kickr.v1.schema.json
version: 1
ci:
  provider: github
  release:
    auth: github-token
  options:
    - codecov
    - codeql
    - harden-runner
    - labeler
    - ossf-scorecard
dependencies:
  manager: renovate
  local: configs/renovate.json5
exclude:
  - shell
license: apache-2.0
maintainers:
  - name: kilianpaquier
platform: github
