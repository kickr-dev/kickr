# Code generated by kickr; DO NOT EDIT.

{{- $golang := hasKey .Languages "go" }}
{{- $terraform := hasKey .Languages "terraform" }}
{{- $shell := and (not (has "shell" .Exclude)) (hasKey .Globs "shell") }}

default_install_hook_types:
  - commit-msg
  - pre-commit

default_stages:
  - pre-commit

repos:
{{- if has "conventional-commits" .PreCommit }}

  # see https://www.conventionalcommits.org/en/v1.0.0/#specification
  - repo: https://github.com/commitizen-tools/commitizen
    # renovate: datasource=github-tags packageName=commitizen-tools/commitizen depName=commitizen
    rev: v4.16.3
    hooks:
      - id: commitizen

  - repo: local
    hooks:
      - id: conventionalcommits-branch
        name: Validate commits specification with conventional commits
        language: script
        entry: scripts/sh/conventionalcommits-branch.sh
        stages: [pre-commit]
        pass_filenames: false
{{- end }}

  - repo: https://github.com/gitleaks/gitleaks
    # renovate: datasource=github-tags packageName=gitleaks/gitleaks depName=gitleaks
    rev: v8.30.1
    hooks:
      - id: gitleaks

  - repo: https://github.com/pre-commit/pre-commit-hooks
    # renovate: datasource=github-tags packageName=pre-commit/pre-commit-hooks depName=pre-commit-hooks
    rev: v6.0.0
    hooks:
      - id: check-merge-conflict
      - id: end-of-file-fixer
      - id: mixed-line-ending
        args: [--fix=lf]
{{- if has "gitflow-branches" .PreCommit }}
      - id: no-commit-to-branch
        args: [--branch, '', --pattern, '^(?!(alpha|beta|dev|develop|main|next|rc|staging|v[0-9]+(\.[0-9]+)?\.x|(chore|docs|feat|fix|release)\/[\w-]+)$).*']
{{- end }}
      - id: trailing-whitespace

{{- if and (not .GitHub) (not .GitLab) $shell }}

  - repo: https://github.com/koalaman/shellcheck-precommit
    # renovate: datasource=github-tags packageName=koalaman/shellcheck-precommit depName=shellcheck-precommit
    rev: v0.11.0
    hooks:
      # see https://www.shellcheck.net/wiki/SC1071
      - id: shellcheck
        types_or: [bash, dash, ksh, sh, shell]
{{- end }}

{{- if and $golang (has "gomod-tidy" .PreCommit) }}

  - repo: local
    hooks:
      - id: tidy
        name: go mod tidy
        entry: bash -c 'go mod tidy'
        language: system
{{- end }}

{{- if and $golang (or (and (not .GitHub) (not .GitLab)) (has "golangci-lint" .PreCommit)) }}

  - repo: https://github.com/golangci/golangci-lint
    # renovate: datasource=github-tags packageName=golangci/golangci-lint depName=golangci-lint
    rev: v2.12.2
    hooks:
      - id: golangci-lint
{{- end }}

{{- if $terraform }}
{{- if not .HasTerraformApply }}

  - repo: https://github.com/terraform-docs/terraform-docs
    # renovate: datasource=github-tags packageName=terraform-docs/terraform-docs depName=terraform-docs
    rev: v0.24.0
    hooks:
{{- range $node := get .Languages "terraform" }}
      - id: terraform-docs-go
        args: ["markdown", "table", "--output-file", "README.md", "{{ $node.Directory }}"]
{{- end }}
{{- end }}

{{- if or (and (not .GitHub) (not .GitLab)) (has "terraform" .PreCommit) }}

{{- $engine := "opentofu" }}
{{- if and .Terraform .Terraform.Engine }}{{- $engine = .Terraform.Engine }}{{- end }}
{{- $cmd := eq $engine "opentofu" | ternary "tofu" "terraform" }}

{{- if eq $engine "terraform" }}

  - repo: https://github.com/antonbabenko/pre-commit-terraform
    # renovate: datasource=github-tags packageName=antonbabenko/pre-commit-terraform depName=pre-commit-terraform
    rev: v1.108.0
{{- else }}

  - repo: https://github.com/tofuutils/pre-commit-opentofu
    # renovate: datasource=github-tags packageName=tofuutils/pre-commit-opentofu depName=pre-commit-opentofu
    rev: v2.4.2
{{- end }}
    hooks:
      - id: {{ $cmd }}_fmt
      - id: {{ $cmd }}_validate
      - id: {{ $cmd }}_tflint
      - id: {{ $cmd }}_trivy
{{- end }}
{{- end }}
