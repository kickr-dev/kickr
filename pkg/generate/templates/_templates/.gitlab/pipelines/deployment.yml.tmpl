# Code generated by kickr; DO NOT EDIT.

{{- $terraform := hasKey .Languages "terraform" }}

---
{{- if or .CI.Docker .CI.Helm $terraform }}
include:
{{- if .CI.Docker }}

  # Docker template
  # https://gitlab.com/to-be-continuous/docker
  - project: to-be-continuous/docker
    ref: e8dd148bb72efa7fd58795b65d816d3859be82d5 # 8.0.8
    file: templates/gitlab-ci-docker.yml
{{- end }}

{{- if .CI.Helm }}

  # Helm template
  # https://gitlab.com/to-be-continuous/helm
  - project: to-be-continuous/helm
    ref: 1f42eedf35c98410b579478b0fd8cc4764b72500 # 9.2.0
    file: templates/gitlab-ci-helm.yml
{{- end }}

{{- if $terraform }}

  # Terraform template
  # https://gitlab.com/to-be-continuous/terraform
  - project: to-be-continuous/terraform
    ref: a705153bf85ef6237a9033f1943221093c0f4111 # 8.1.2
    file: templates/gitlab-ci-terraform.yml
{{- end }}

variables:
{{- if .CI.Docker }}
{{- $registry := .CI.Docker.Registry | default "$CI_REGISTRY" }}
{{- $path := .CI.Docker.Path | default "$CI_PROJECT_PATH" }}

  DOCKER_RELEASE_IMAGE: "{{ $registry }}/{{ $path }}:$SEMREL_INFO_NEXT_VERSION"
  DOCKER_SNAPSHOT_IMAGE: "{{ $registry }}/{{ $path }}/snapshot:$SEMREL_INFO_NEXT_VERSION"

  DOCKER_BUILD_TOOL: buildah
  DOCKER_HEALTHCHECK_DISABLED: "true" # https://docs.docker.com/reference/dockerfile/#healthcheck
  DOCKER_BUILD_ARGS: |
    --build-arg GIT_REF_NAME=$CI_COMMIT_REF_NAME
    --build-arg GIT_COMMIT=$CI_COMMIT_SHA
    --build-arg VERSION=$SEMREL_INFO_NEXT_VERSION
    --label org.opencontainers.image.created=$CI_JOB_STARTED_AT
    --label org.opencontainers.image.ref.name=$CI_COMMIT_REF_NAME
    --label org.opencontainers.image.revision=$CI_COMMIT_SHA
    --label org.opencontainers.image.version=$SEMREL_INFO_NEXT_VERSION
  DOCKER_RELEASE_EXTRA_TAGS: latest \\g<major>.\\g<minor> \\g<major
  DOCKER_SBOM_DISABLED: "true" # https://github.com/anchore/syft
  DOCKER_SEMREL_RELEASE_DISABLED: "true" # handled by docker build and push jobs to avoid too much dependency on semantic-release
  DOCKER_TRIVY_ARGS: --ignore-unfixed --exit-code 1 --exit-on-eol 1
  TRIVY_SEVERITY: MEDIUM,HIGH,CRITICAL
{{- end }}

{{- if .CI.Helm }}
{{- $registry := .CI.Helm.Registry | default "oci://$CI_REGISTRY" }}
{{- $path := .CI.Helm.Path | default "$CI_PROJECT_PATH/charts" }}

  HELM_CHART_DIR: chart/
  HELM_SCRIPTS_DIR: chart/hooks/
  HELM_SEMREL_RELEASE_DISABLED: "true" # version is handled manually
  HELM_TEST_ENABLED: "false"

  HELM_PACKAGE_ARGS: package --version "$SEMREL_INFO_NEXT_VERSION" --app-version "$SEMREL_INFO_NEXT_VERSION" --dependency-update
  HELM_PUBLISH_METHOD: {{ .HasHelmPublish | ternary "push" "disabled" }}
  HELM_PUBLISH_ON: {{ .HasHelmPublish | ternary "all" "none" }}
  HELM_PUBLISH_SNAPSHOT_ENABLED: "false"
  HELM_PUBLISH_STRATEGY: {{ .CI.Helm.Publish | default "none" }}
{{- if .HasHelmPublish }}
  HELM_PUBLISH_URL: {{ $registry }}/{{ trimSuffix (print "/" .VCS.ProjectName) $path }}
{{- end }}

{{- if .HasHelmDeploy }}

  HELM_REVIEW_ENABLED: "{{ has "review" .CI.Helm.Environments }}"
  HELM_INTEG_ENABLED: "{{ has "integration" .CI.Helm.Environments }}"
  HELM_STAGING_ENABLED: "{{ has "staging" .CI.Helm.Environments }}"
  HELM_PROD_ENABLED: "{{ has "production" .CI.Helm.Environments }}"

  HELM_DEPLOY_ARGS: upgrade --install --version "$SEMREL_INFO_NEXT_VERSION" -f "$HELM_CHART_DIR/values.yaml" --set "appVersion=$SEMREL_INFO_NEXT_VERSION"
{{- if has "production" .CI.Helm.Environments }}
  HELM_PROD_DEPLOY_STRATEGY: {{ .CI.Helm.Deploy }}
{{- end }}

  HELM_INTEG_APP_NAME: $HELM_BASE_APP_NAME
  HELM_REVIEW_APP_NAME: $HELM_BASE_APP_NAME-$SEMREL_INFO_NEXT_VERSION
  HELM_STAGING_APP_NAME: $HELM_BASE_APP_NAME
{{- end }}
{{- end }}

{{- if $terraform }}
{{- $engine := "opentofu" }}
{{- if and .Terraform .Terraform.Engine }}{{- $engine = .Terraform.Engine }}{{- end }}

  TF_IMAGE: {{ eq $engine "terraform" | ternary "docker.io/hashicorp/terraform:latest" "ghcr.io/opentofu/opentofu:latest" }}
  TF_TFLINT_ARGS: --config "$CI_PROJECT_DIR/.tflint.hcl" --recursive

  TF_CHECKOV_ENABLED: "false"
  TF_FMT_ENABLED: "true"
  TF_TRIVY_DISABLED: "true"
  TF_VALIDATE_ENABLED: "true"

{{- if .HasTerraformApply }}

  TF_REVIEW_ENABLED: "{{ has "review" .CI.Terraform.Environments }}"
  TF_INTEG_ENABLED: "{{ has "integration" .CI.Terraform.Environments }}"
  TF_STAGING_ENABLED: "{{ has "staging" .CI.Terraform.Environments }}"
  TF_PROD_ENABLED: "{{ has "production" .CI.Terraform.Environments }}"
{{- end }}
{{- end }}
{{- end }}

{{- if .CI.Website }}{{ template "static" . }}{{- end }}

{{- if $terraform }}
{{- $nodes := get .Languages "terraform" }}

.tf-workspace:
  variables:
{{- if eq (len $nodes) 1 }}
{{- $firstnode := first $nodes }}
{{- if ne $firstnode.Directory "." }}
    TF_PROJECT_DIR: {{ $firstnode.Directory }}
{{- end }}
{{- if ne $firstnode.Specifics.Backend "http" }}
    TF_GITLAB_BACKEND_DISABLED: "true"
{{- end }}
{{- end }}
{{- if gt (len $nodes) 1 }}
    TF_BASE_ADDRESS: ${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/terraform/state
  parallel:
    matrix:
{{- range $nodes }}
      - TF_PROJECT_DIR: {{ .Directory }}
{{- if ne .Specifics.Backend "http" }}
        TF_GITLAB_BACKEND_DISABLED: "true"
{{- end }}
{{- if ne .Directory "." }}
        # see https://gitlab.com/to-be-continuous/terraform/-/blob/master/templates/gitlab-ci-terraform.yml?ref_type=heads#L774
        TF_ADDRESS: ${TF_BASE_ADDRESS}/{{ sha256sum .Directory | trunc 8 }}.${CI_ENVIRONMENT_SLUG}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
