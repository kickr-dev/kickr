# Code generated by kickr; DO NOT EDIT.

{{- $golang := hasKey .Languages "go" }}
{{- $hugo := hasKey .Languages "hugo" }}

{{- $node := hasKey .Languages "node" }}
{{- $nodemain := and $node (get .Languages "node").HasMain }}

{{- $precommit := not (has "pre-commit" .Exclude) }}
{{- $shell := and (not (has "shell" .Exclude)) (hasKey .Globs "shell") }}

---
include:
{{- if $precommit }}

  # pre-commit template
  # https://gitlab.com/to-be-continuous/pre-commit
  - project: to-be-continuous/pre-commit
    ref: 85ef9be998d1cbabe018eb1b293c09c0c07d448c # 1.4.1
    file: templates/gitlab-ci-pre-commit.yml
{{- end }}

{{- if $shell }}

  # Bash template
  # https://gitlab.com/to-be-continuous/bash
  - project: to-be-continuous/bash
    ref: f0d0f552b82c60dfb14eee9eb06c1259f7ec0925 # 3.9.0
    file: /templates/gitlab-ci-bash.yml
{{- end }}

{{- if $golang }}

  # Go template
  # https://gitlab.com/to-be-continuous/golang
  - project: to-be-continuous/golang
    ref: 156a4275a22b839532e8c6acb825b8cadc065103 # 4.15.1
    file: templates/gitlab-ci-golang.yml
{{- end }}

{{- if $node }}

  # Node.js template
  # https://gitlab.com/to-be-continuous/node
  - project: to-be-continuous/node
    ref: f67302a5a04e265da76c373a7e95c9f5e242d12f # 5.0.2
    file: templates/gitlab-ci-node.yml
{{- end }}

{{- if has "sonarqube" .CI.Options }}

  # SonarQube template
  # https://gitlab.com/to-be-continuous/sonar
  - project: to-be-continuous/sonar
    ref: 0c896035e9c6310400205238880aed887823b14c # 5.0.1
    file: "templates/gitlab-ci-sonar.yml"
{{- end }}

variables:
{{- if or $hugo $nodemain }}
  BUILD_DIR: dist
{{- end }}

{{- if $precommit }}
  PRE_COMMIT_FILE: .pre-commit-config.yaml
{{- end }}

{{- if $shell }}
  BASH_SHELLCHECK_FILES: "**/*.*sh"
  BASH_BATS_ENABLED: "false"
{{- end }}

{{- if $golang }}

  GO_CI_LINT_ARGS: --config=.golangci.yml --timeout=240s --allow-parallel-runners --output.checkstyle.path="reports/go-ci-lint.checkstyle.xml" --output.text.path=stdout
  GO_CI_LINT_IMAGE: docker.io/golangci/golangci-lint:latest-alpine
  GO_IMAGE: docker.io/library/golang:latest
  GO_OUTDATED_DISABLED: "false" # https://github.com/psampaz/go-mod-outdated
  GO_SBOM_DISABLED: "true"
  GO_TEST_FLAGS: -v -coverpkg=./... -covermode=count -timeout=30s
  GO_TEST_IMAGE: docker.io/library/golang:latest
{{- end }}

{{- if $node }}

  NODE_AUDIT_DISABLED: "false"
  NODE_BUILD_ARGS: run build --prod
  NODE_BUILD_DIR: $BUILD_DIR
  NODE_BUILD_DISABLED: "{{ not $nodemain }}"
  NODE_IMAGE: docker.io/library/node:lts-alpine
  NODE_LINT_ARGS: "run lint"
  NODE_LINT_ENABLED: "true"
  NODE_OUTDATED_ARGS: --long
  NODE_OUTDATED_DISABLED: "false"
  NODE_PUBLISH_ENABLED: "false"
  NODE_SBOM_DISABLED: "true"
  NODE_SEMGREP_DISABLED: "false" # https://semgrep.dev/docs/
  NODE_TEST_ARGS: test -- --coverage
{{- end }}

{{- if has "sonarqube" .CI.Options }}

  SONAR_BASE_ARGS: |
    -Dsonar.properties=sonar.properties
    -Dsonar.links.homepage=$CI_PROJECT_URL
    -Dsonar.links.ci=$CI_PROJECT_URL/-/pipelines
    -Dsonar.links.issue=$CI_PROJECT_URL/-/issues
  SONAR_QUALITY_GATE_ENABLED: "true"
{{- end }}

{{- if and $precommit (or (has "conventional-commits" .PreCommit) (has "gitflow-branches" .PreCommit)) }}

pre-commit:
  variables:
{{- if has "conventional-commits" .PreCommit }}
    GIT_DEPTH: "0"
{{- end }}
{{- if has "gitflow-branches" .PreCommit }}
    GIT_STRATEGY: clone
  before_script:
    # see https://gitlab.com/to-be-continuous/pre-commit/-/blob/main/templates/gitlab-ci-pre-commit.yml?ref_type=heads#L429
    - !reference [.pre-commit-scripts]
    - install_ca_certs "${CUSTOM_CA_CERTS:-$DEFAULT_CA_CERTS}"
    - apk add git
    - git checkout -b "$CI_COMMIT_REF_NAME"
{{- end }}
{{- end }}

{{- if $shell }}

.bash-base:
  needs: []
{{- end }}

{{- if $golang }}
{{- if gt .Binaries 0 }}

go-build:
  image:
    name: ghcr.io/goreleaser/goreleaser:latest
    entrypoint: [""]
  rules:
    # https://gitlab.com/to-be-continuous/golang/-/blob/master/templates/gitlab-ci-golang.yml?ref_type=heads#L670
    - if: $GO_TEST_IMAGE != ""
      exists:
        - .goreleaser.yml
  variables:
    VERSION: $SEMREL_INFO_NEXT_VERSION
  script:
    - goreleaser release --clean --config .goreleaser.yml --skip=validate --skip=announce --skip=publish --snapshot
  artifacts:
    name: "$CI_JOB_NAME artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - dist/
    exclude:
      - dist/*.json
      - dist/*.yaml
      - dist/*/
    expire_in: 1 day
{{- else }}

go-build:
  rules:
    - when: never # no binary to build
{{- end }}
{{- end }}

{{- if $node }}
{{- $nodes := get .Languages "node" }}
{{- $firstnode := first $nodes }}
{{- if or (gt (len $nodes) 1) (ne $firstnode.Directory ".") }}

.node-base:
{{- if and (eq (len $nodes) 1) (ne $firstnode.Directory ".") }}
  variables:
    NODE_PROJECT_DIR: {{ $firstnode.Directory }}
{{- end }}
{{- if gt (len $nodes) 1 }}
  parallel:
    matrix:
{{- range $nodes }}
      - NODE_PROJECT_DIR: {{ .Directory }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

{{- if $hugo }}
{{- $nodes := get .Languages "hugo" }}

hugo-build:
  image: hugomods/hugo:exts
  stage: build
{{- if and (eq (len $nodes) 1) (ne (first $nodes).Directory ".") }}
  variables:
    HUGO_PROJECT_DIR: {{ (first $nodes).Directory }}
{{- end }}
{{- if gt (len $nodes) 1 }}
  parallel:
    matrix:
{{- range $nodes }}
      - HUGO_PROJECT_DIR: {{ .Directory }}
{{- end }}
{{- end }}
  before_script:
    - apk add go
  script:
    - >
      [ -z "$HUGO_PROJECT_DIR" ] || cd "$HUGO_PROJECT_DIR"
    - hugo --gc --minify --destination "$CI_PROJECT_DIR/$BUILD_DIR" --logLevel "${LOG_LEVEL:-info}"
  artifacts:
    name: "$CI_JOB_NAME artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - $BUILD_DIR
    expire_in: 1 day
{{- end }}
