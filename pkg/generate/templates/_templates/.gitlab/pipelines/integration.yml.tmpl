{{- $nodemain := and $node (get .Languages "node").HasMain }}

{{- $precommit := not (has "pre-commit" .Exclude) }}
{{- $shell := and (not (has "shell" .Exclude)) (hasKey .Globs "shell") }}

---
include:
{{- if $precommit }}

  # pre-commit template
  # https://gitlab.com/to-be-continuous/pre-commit
  - project: to-be-continuous/pre-commit
    ref: 781cb6e8a6a4009a4ca29357fd6aa1a81f9867cd # 1.4.2
    file: templates/gitlab-ci-pre-commit.yml
{{- end }}

{{- if $shell }}

  # Bash template
  # https://gitlab.com/to-be-continuous/bash
  - project: to-be-continuous/bash
    ref: 1a8caffe3c41e11722b09db3cb694ea621ee5808 # 3.9.2
    file: /templates/gitlab-ci-bash.yml
{{- end }}

{{- if $golang }}

  # Go template
  # https://gitlab.com/to-be-continuous/golang
  - project: to-be-continuous/golang
    ref: 473da325602b2a247fc6d880bc243cf6a42dbe0f # 4.15.3
    file: templates/gitlab-ci-golang.yml
{{- end }}

{{- if $node }}

  # Node.js template
  # https://gitlab.com/to-be-continuous/node
  - project: to-be-continuous/node
    ref: 9cd9971a60e28c5c86486b5bc5c0a9af8ccc83d0 # 5.1.0
    file: templates/gitlab-ci-node.yml
{{- end }}

{{- if has "sonarqube" .CI.Options }}

  # SonarQube template
  # https://gitlab.com/to-be-continuous/sonar
  - project: to-be-continuous/sonar
    ref: d634d32af33537fd47106ada357051f1abb136ca # 5.0.2
    file: "templates/gitlab-ci-sonar.yml"
{{- end }}

variables:
{{- if or $hugo $nodemain }}
  BUILD_DIR: dist
{{- end }}

{{- if $precommit }}
  PRE_COMMIT_FILE: .pre-commit-config.yaml
{{- end }}

{{- if $shell }}
  BASH_SHELLCHECK_FILES: "**/*.*sh"
  BASH_BATS_ENABLED: "false"
{{- end }}

{{- if $golang }}
{{- $specifics := get .Languages "go" }}

  GO_BUILD_MODE: modules
  GO_CI_LINT_ARGS: --config=.golangci.yml --timeout=240s --allow-parallel-runners --output.checkstyle.path="reports/go-ci-lint.checkstyle.xml" --output.text.path=stdout
  GO_SBOM_OPTS: -licenses -assert-licenses
  GO_TEST_FLAGS: -v -coverpkg=./... -covermode=count -timeout=30s
{{- if $gobuild }}
  GO_TEST_IMAGE: $GO_IMAGE
{{- end }}
{{- end }}

{{- if $node }}

  NODE_BUILD_DIR: $BUILD_DIR
  NODE_LINT_ENABLED: "true"
  NODE_LINT_ARGS: run lint -- --ignore-pattern .bun --ignore-pattern .npm --ignore-pattern .yarn
{{- end }}

{{- if has "sonarqube" .CI.Options }}

  SONAR_BASE_ARGS: |
    -Dsonar.properties=sonar.properties
    -Dsonar.links.homepage=$CI_PROJECT_URL
    -Dsonar.links.ci=$CI_PROJECT_URL/-/pipelines
    -Dsonar.links.issue=$CI_PROJECT_URL/-/issues
  SONAR_QUALITY_GATE_ENABLED: "true"
{{- end }}

{{- if and $precommit (or (has "conventional-commits" .PreCommit) (has "gitflow-branches" .PreCommit)) }}

pre-commit:
  variables:
{{- if has "conventional-commits" .PreCommit }}
    GIT_DEPTH: "0"
{{- end }}
{{- if has "gitflow-branches" .PreCommit }}
    GIT_STRATEGY: clone
  before_script:
    # see https://gitlab.com/to-be-continuous/pre-commit/-/blob/main/templates/gitlab-ci-pre-commit.yml?ref_type=heads#L430
    - !reference [.pre-commit-scripts]
    - install_ca_certs "${CUSTOM_CA_CERTS:-$DEFAULT_CA_CERTS}"
    - apk add git
    - git checkout -b "$CI_COMMIT_REF_NAME"
{{- end }}
{{- end }}

{{- if $gobuild }}

go-build:
  image:
    name: ghcr.io/goreleaser/goreleaser:latest
    entrypoint: [""]
  needs:
    - semantic-release-info
  rules:
    - if: '$CI_PIPELINE_SOURCE == "schedule"'
      when: never
    # https://gitlab.com/to-be-continuous/golang/-/blob/master/templates/gitlab-ci-golang.yml?ref_type=heads#L670
    - if: $GO_TEST_IMAGE != ""
      exists:
        - .goreleaser.yml
  script:
    - goreleaser release --clean --config .goreleaser.yml --skip=announce --skip=publish --skip=validate
  artifacts:
    name: "$CI_JOB_NAME artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - dist
    expire_in: 1 day
{{- end }}

{{- if $node }}
{{- $nodes := get .Languages "node" }}

.node-base:
{{- if eq (len $nodes) 1 }}
{{- $firstnode := first $nodes }}
  variables:
    NODE_PROJECT_DIR: {{ $firstnode.Directory }}
    NODE_PUBLISH_ENABLED: "{{ and (not .CI.Release) (not $firstnode.Specifics.Private) }}"
{{- else }}
  parallel:
    matrix:
{{- range $nodes }}
      - NODE_PROJECT_DIR: {{ .Directory }}
        JOB_MATRIX_NAMESPACE: /$NODE_PROJECT_DIR
        NODE_PUBLISH_ENABLED: "{{ and (not .CI.Release) (not .Specifics.Private) }}"
{{- end }}
{{- end }}

node-audit:
  allow_failure: true

node-build:
  needs:
    - semantic-release-info
{{- end }}

{{- if $hugo }}
{{- $nodes := get .Languages "hugo" }}

hugo-build:
  image: docker.io/library/debian:trixie-slim
  stage: build
  needs:
    - semantic-release-info
  variables:
{{- if and (eq (len $nodes) 1) (ne (first $nodes).Directory ".") }}
    HUGO_PROJECT_DIR: {{ (first $nodes).Directory }}
{{- end }}
    # renovate: datasource=github-tags packageName=jdx/mise depName=mise
    MISE_VERSION: v2026.1.6
{{- if gt (len $nodes) 1 }}
  parallel:
    matrix:
{{- range $nodes }}
      - HUGO_PROJECT_DIR: {{ .Directory }}
{{- end }}
{{- end }}
  rules:
    - !reference [.test-policy, rules]
  before_script:
    - export PATH="$HOME/.local/share/mise/shims:$PATH"
    - apt-get update -yq && apt-get install -yq curl git
    - curl https://mise.run | MISE_INSTALL_PATH=/usr/local/bin/mise MISE_VERSION=$MISE_VERSION sh
    # renovate: datasource=golang-version packageName=golang/go depName=golang
    - mise use -g golang@1.25.5
    # renovate: datasource=github-tags packageName=gohugoio/hugo depName=hugo
    - mise use -g hugo-extended@0.153.2
    # renovate: datasource=github-tags packageName=sass/dart-sass depName=dart-sass
    - mise use -g github:sass/dart-sass@1.97.2
  script:
    - >
      [ -z "$HUGO_PROJECT_DIR" ] || cd "$HUGO_PROJECT_DIR"
    - hugo --gc --minify --destination "$CI_PROJECT_DIR/$BUILD_DIR" --logLevel "${LOG_LEVEL:-info}"
  artifacts:
    name: "$CI_JOB_NAME artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - $BUILD_DIR
    expire_in: 1 day
{{- end }}
