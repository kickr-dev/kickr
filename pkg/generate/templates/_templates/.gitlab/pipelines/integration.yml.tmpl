# Code generated by kickr; DO NOT EDIT.

{{- $golang := hasKey .Languages "go" }}
{{- $hugo := hasKey .Languages "hugo" }}

{{- $node := hasKey .Languages "node" }}
{{- $nodemain := and $node (get .Languages "node").HasMain }}

{{- $precommit := and (not (has "pre-commit" .Exclude)) (not (has "pre-commit" .GitLab.Exclude)) }}
{{- $shell := and (not (has "shell" .Exclude)) (hasKey .Globs "shell") }}

---
include:
{{- if $precommit }}

  # pre-commit template
  # https://gitlab.com/to-be-continuous/pre-commit
  - remote: https://gitlab.com/to-be-continuous/pre-commit/-/raw/805b30e6daceca57eae1296f7864bd65577c0b40/templates/gitlab-ci-pre-commit.yml # 1.5.0
    inputs:
      pre-commit-file: .pre-commit-config.yaml
{{- end }}

{{- if $shell }}

  # Bash template
  # https://gitlab.com/to-be-continuous/bash
  - remote: https://gitlab.com/to-be-continuous/bash/-/raw/25e0ab61ffadef08b7cda4032afbaa859aebc280/templates/gitlab-ci-bash.yml # 3.10.0
    inputs:
      bats-enabled: "false"
      shellcheck-files: "**/*.*sh"
{{- end }}

{{- if $golang }}

  # Go template
  # https://gitlab.com/to-be-continuous/golang
  - remote: https://gitlab.com/to-be-continuous/golang/-/raw/8a3028125ed0e16d9ad1be4fee6c2905e64915b0/templates/gitlab-ci-golang.yml # 4.16.0
    inputs:
      build-mode: modules
      ci-lint-args: --config=.golangci.yml --timeout=300s --allow-parallel-runners --output.checkstyle.path="reports/go-ci-lint.checkstyle.xml" --output.text.path=stdout
      sbom-opts: -licenses -assert-licenses
      test-flags: -v -coverpkg=./... -covermode=count -timeout=30s
{{- if and $golang (gt .Binaries 0) }}
      test-image: $GO_IMAGE
{{- end }}
{{- end }}

{{- if $node }}
{{- $nodes := get .Languages "node" }}

  # Node.js template
  # https://gitlab.com/to-be-continuous/node
  - remote: https://gitlab.com/to-be-continuous/node/-/raw/f7977da89f556dc703580eb16412b1ec7e4f0ae9/templates/gitlab-ci-node.yml # 5.3.0
    inputs:
      build-dir: $BUILD_DIR
      lint-enabled: "true"
      lint-args: run lint --ignore-pattern .bun --ignore-pattern .npm --ignore-pattern .yarn
{{- if eq (len $nodes) 1 }}
{{- $firstnode := first $nodes }}
{{- if ne $firstnode.Directory "." }}
      project-dir: {{ $firstnode.Directory }}
{{- end }}
      publish-enabled: "{{ and (not .GitLab.Release) (not $firstnode.Specifics.Private) }}"
{{- end }}
{{- end }}

{{- if has "sonarqube" .GitLab.Options }}

  # SonarQube template
  # https://gitlab.com/to-be-continuous/sonar
  - remote: https://gitlab.com/to-be-continuous/sonar/-/raw/6c935b3d0368ca8c8603017f3fbc5303eb117829/templates/gitlab-ci-sonar.yml # 5.3.0
    inputs:
      base-args: |
        -Dsonar.properties=sonar.properties
        -Dsonar.links.homepage=$CI_PROJECT_URL
        -Dsonar.links.ci=$CI_PROJECT_URL/-/pipelines
        -Dsonar.links.issue=$CI_PROJECT_URL/-/issues
      quality-gate-enabled: "true"
{{- end }}

{{- if has "overrides:integration" .GitLab.Options }}
  - local: .gitlab/integration.overrides.yml
{{- end }}

{{- if and $precommit (or (has "conventional-commits" .PreCommit) (has "gitflow-branches" .PreCommit)) }}

pre-commit:
  variables:
{{- if has "conventional-commits" .PreCommit }}
    GIT_DEPTH: "0"
{{- end }}
{{- if has "gitflow-branches" .PreCommit }}
    GIT_STRATEGY: clone
  before_script:
    # see https://gitlab.com/to-be-continuous/pre-commit/-/blob/main/templates/gitlab-ci-pre-commit.yml?ref_type=heads#L430
    - !reference [.pre-commit-scripts]
    - install_ca_certs "${CUSTOM_CA_CERTS:-$DEFAULT_CA_CERTS}"
    - apk add git
    - git checkout -b "$CI_COMMIT_REF_NAME"
{{- end }}
{{- end }}

{{- if $golang }}

go-govulncheck:
  allow_failure: true

{{- if gt (len .Clis) 0 }}

go-build:
  image:
    name: $GO_GORELEASER_IMAGE
    entrypoint: [""]
  needs:
    - semantic-release-info
  rules:
    # https://gitlab.com/to-be-continuous/golang/-/blob/master/templates/gitlab-ci-golang.yml?ref_type=heads#L670
    - if: '$GO_TEST_IMAGE != ""'
  script:
    - goreleaser release --clean --config .goreleaser.yml --snapshot
  artifacts:
    name: "$CI_JOB_NAME artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - dist
    expire_in: 1 day
{{- else if gt .Binaries 0 }}

go-build:
  rules: [when: never]
{{- end }}
{{- end }}

{{- if $node }}
{{- $nodes := get .Languages "node" }}
{{- if ne (len $nodes) 1 }}

.node-base:
  parallel:
    matrix:
{{- range $nodes }}
      - NODE_PROJECT_DIR: {{ .Directory }}
        JOB_MATRIX_NAMESPACE: /$NODE_PROJECT_DIR
        NODE_PUBLISH_ENABLED: "{{ and (not .GitLab.Release) (not .Specifics.Private) }}"
{{- end }}
{{- end }}

node-audit:
  allow_failure: true

node-build:
  needs:
    - semantic-release-info
{{- end }}

{{- if $hugo }}
{{- $nodes := get .Languages "hugo" }}

hugo-build:
  image:
    name: $HUGO_IMAGE
    entrypoint: [""]
  stage: build
  needs:
    - semantic-release-info
{{- if and (eq (len $nodes) 1) (ne (first $nodes).Directory ".") }}
  variables:
    HUGO_PROJECT_DIR: {{ (first $nodes).Directory }}
{{- end }}
{{- if gt (len $nodes) 1 }}
  parallel:
    matrix:
{{- range $nodes }}
      - HUGO_PROJECT_DIR: {{ .Directory }}
{{- end }}
{{- end }}
  rules:
    - !reference [.test-policy, rules]
  script:
    - |
      [ -z "$HUGO_PROJECT_DIR" ] || cd "$HUGO_PROJECT_DIR"
    - hugo --gc --minify --destination "$CI_PROJECT_DIR/$BUILD_DIR" --logLevel "${LOG_LEVEL:-info}"
  artifacts:
    name: "$CI_JOB_NAME artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - $BUILD_DIR
    expire_in: 1 day
{{- end }}
