{{- $hugo := hasKey .Languages "hugo" }}
{{- $shell := and (not (has "shell" .Exclude)) (hasKey .Globs "shell") }}

{{- $node := hasKey .Languages "node" }}
{{- $nodemain := and $node (get .Languages "node").HasMain }}

{{- $precommit := not (has "pre-commit" .Exclude) }}

{{- $terraform := hasKey .Languages "terraform" }}

---
include:
{{- if and (.DependencyManager "renovate") (has "renovate" .CI.Options) }}
  # Renovate template
  # https://gitlab.com/to-be-continuous/renovate
  - project: to-be-continuous/renovate
    ref: 8969ef02fd9a715e9599d89d70ec06c5ee883ea5 # 1.12.0
    file: templates/gitlab-ci-renovate.yml
{{- end }}

{{- if .DependencyManager "dependabot" }}
  # Dependabot template
  # https://gitlab.com/dependabot-gitlab/dependabot-standalone
  - project: dependabot-gitlab/dependabot-standalone
    ref: d9cffad9458bac4e6ffef4eeb96b7abd42a5620b # 3.74.0
    file: .gitlab-ci.yml
{{- end }}

variables:
{{- if .DependencyManager "dependabot" }}
  SETTINGS__GITLAB_URL: $CI_SERVER_FQDN
{{- end }}

{{- if and (.DependencyManager "renovate") (has "renovate" .CI.Options) }}
  RENOVATE_CONFIG_FILE: .gitlab/renovate.json
  RENOVATE_ENDPOINT: "" # force empty endpoint to let Renovate choose with RENOVATE_PLATFORM (or server configuration platform)
  RENOVATE_PLATFORM: {{ .VCS.Platform }}
{{- end }}

{{- if and (.DependencyManager "renovate") (has "renovate" .CI.Options) }}

.renovate-rules: &renovate-rules
  rules:
    # see https://gitlab.com/to-be-continuous/renovate/-/blob/master/templates/gitlab-ci-renovate.yml?ref_type=heads#L348
    # update mode only with schedule triggering
    - if: $CI_PIPELINE_SOURCE == 'schedule'
      variables:
        RENOVATE_DRY_RUN: "false"
    # dry run with web triggering
    - if: $CI_PIPELINE_SOURCE == 'web'

renovate-validator:
  rules:
    - when: never # validates projects configurations and not server configurations

renovate-depcheck:
  <<: *renovate-rules
{{- end }}
