{{- define "static" }}

{{- $hugo := hasKey .Languages "hugo" }}
{{- $node := hasKey .Languages "node" }}

{{- $websiteDirectory := .Website.Directory | default "." }}

{{- $needs := "" }}
{{- if $node }}{{- range (get .Languages "node") }}{{- if eq .Directory $websiteDirectory }}{{- $needs = "node-build" }}{{- end }}{{- end }}{{- end }}
{{- if $hugo }}{{- range (get .Languages "hugo") }}{{- if eq .Directory $websiteDirectory }}{{- $needs = "hugo-build" }}{{- end }}{{- end }}{{- end }}

{{- $matrix := or (and (eq $needs "node-build") (gt (len (get .Languages "node")) 1)) (and (eq $needs "hugo-build") (gt (len (get .Languages "hugo")) 1)) }}

{{- if eq .Website.Hosting "netlify" }}
netlify:
  image: $NETLIFY_IMAGE
  stage: deploy
  environment:
    name: $ENV
    action: start
  dependencies:
    - {{ not $matrix | ternary $needs (printf "%s: [%s]" $needs $websiteDirectory | quote) }}
  rules:
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH
      variables:
        ARGS: --prod
        ENV: production
{{- if not .Website.Auto }}
      when: manual
{{- end }}
    - variables:
        ARGS: --alias=$BRANCH_SHA
        ENV: review/$CI_COMMIT_REF_NAME
      when: manual
      allow_failure: true
  before_script:
    - npm install -g netlify-cli
  script:
    - netlify deploy --site "$NETLIFY_SITE_ID" --auth "$NETLIFY_AUTH_TOKEN" --dir "$BUILD_DIR" $ARGS
{{- end }}

{{- if eq .Website.Hosting "pages" }}
pages:
  image: $PAGES_IMAGE
  stage: deploy
  environment:
    name: $ENV
    action: start
    url: $CI_PAGES_URL
  variables:
    ENV: production
  dependencies:
    - {{ not $matrix | ternary $needs (printf "%s: [%s]" $needs $websiteDirectory | quote) }}
  rules:
    - if: $CI_COMMIT_REF_NAME == $CI_DEFAULT_BRANCH
{{- if not .Website.Auto }}
      when: manual
{{- end }}
  script:
    - |
      if [ "$BUILD_DIR" != "public" ]; then
        mkdir -p public
        mv "$BUILD_DIR"/* public
      fi
  artifacts:
    name: "$CI_JOB_NAME artifacts from $CI_PROJECT_NAME on $CI_COMMIT_REF_SLUG"
    paths:
      - public
    expire_in: 1 day
{{- end }}
{{- end }}
