{{- $golang := hasKey .Languages "go" }}
{{- $helm := and .CI .CI.Helm }}
{{- $hugo := hasKey .Languages "hugo" }}
{{- $node := hasKey .Languages "node" }}

version: 2
enable-beta-ecosystems: true
updates:
{{- if and (not .HasKickr) (.IsCI "github") }}

  - package-ecosystem: github-actions
    directory: /
    labels:
      - dependabot
      - dependencies
    schedule:
      interval: daily
      time: "12:00"
      timezone: "Etc/UTC"
    groups:
      major/minor/patch:
        update-types:
          - major
          - minor
          - patch
    commit-message:
      include: scope
      prefix: ci
    cooldown:
      default-days: 5
{{- end }}

{{- if (hasKey .Globs "gitmodules") }}

  - package-ecosystem: gitsubmodule
    directory: /
    labels:
      - dependabot
      - dependencies
    schedule:
      interval: daily
      time: "12:00"
      timezone: "Etc/UTC"
    groups:
      major/minor/patch:
        update-types:
          - major
          - minor
          - patch
    commit-message:
      include: scope
      prefix: ci
    cooldown:
      default-days: 5
{{- end }}

{{- if and .CI .CI.Docker }}

