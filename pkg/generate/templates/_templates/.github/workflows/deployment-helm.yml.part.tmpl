jobs:
<<- define "helm" >>

<<- $golang := hasKey .Languages "go" >>
<<- $node := hasKey .Languages "node" >>

<<- $registry := .Helm.Registry | default "oci://ghcr.io" >>
<<- $path := .Helm.Path | default .VCS.ProjectPath >>
<<- $ghcr := and (eq $registry "oci://ghcr.io") (eq $path .VCS.ProjectPath) >>

<<- if .HasHelmPublish >>

  helm-push:
    name: Helm Push
    runs-on: ubuntu-latest
    if: ${{ inputs.helm_push != 'none' }}
    needs:
<<- if .Docker >>
      - docker-build
<<- end >>
      - version
    permissions:
      packages: << $ghcr | ternary "write" "none" >>
    steps:
<<- if has "harden-runner" .GitHub.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@a5ad31d6a139d249332a2605b85202e8c0b78450 # v2.19.1
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      # https://github.com/marketplace/actions/helm-tool-installer
      - uses: azure/setup-helm@1a275c3b69536ee54be43f2070a358922e12c8d4 # v4.3.1
        with:
          # renovate: datasource=github-tags packageName=helm/helm depName=helm
          version: v4.1.4
      - run: helm package --version "$VERSION" --app-version "$VERSION" --dependency-update "$HELM_CHART_DIR"
        env:
          HELM_CHART_DIR: chart/
          VERSION: ${{ needs.version.outputs.version }}
      - run: |-
<<- if not (hasPrefix "oci://" $registry) >>
          helm plugin install https://github.com/chartmuseum/helm-push
<<- end >>
          helm registry login "$HELM_REGISTRY" -u "$HELM_REPO_USERNAME" -p "$HELM_REPO_ACCESS_TOKEN"
          if [ "$HELM_DRY_RUN" = "false" ]; then
            helm << hasPrefix "oci://" $registry | ternary "push" "cm-push" >> "$HELM_CHART_PATH" "$HELM_PUBLISH_URL"
          else
            echo "should push $HELM_CHART_PATH to $HELM_PUBLISH_URL"
          fi
        env:
          HELM_CHART_PATH: ${{ github.event.repository.name }}-${{ needs.version.outputs.version }}.tgz
          HELM_DRY_RUN: ${{ inputs.helm_push != 'full' }}
          HELM_PUBLISH_URL: << $registry >>/<< trimSuffix (print "/" .VCS.ProjectName) $path >>
          HELM_REGISTRY: << trimPrefix "oci://" $registry >>
<<- if $ghcr >>
          HELM_REPO_ACCESS_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          HELM_REPO_USERNAME: ${{ github.repository_owner }}
<<- else >>
          HELM_REPO_ACCESS_TOKEN: ${{ secrets.HELM_REPO_ACCESS_TOKEN || secrets.HELM_REPO_PASSWORD }}
          HELM_REPO_AUTH_HEADER: ${{ secrets.HELM_REPO_AUTH_HEADER }}
          HELM_REPO_USE_HTTP: ${{ secrets.HELM_REPO_USE_HTTP }}
          HELM_REPO_USERNAME: ${{ secrets.HELM_REPO_USERNAME || github.repository_owner }}
<<- end >>
<<- end >>

<<- if .HasHelmDeploy >>

  helm-deploy:
    name: Helm Deploy (${{ matrix.environment }})
    runs-on: ubuntu-latest
    if: ${{ inputs.helm_deploy != 'none' }}
    needs:
<<- if .HasHelmPublish >>
      - helm-push
<<- else if .Docker >>
      - docker-build
<<- end >>
      - version
    environment: ${{ matrix.environment }}
    strategy:
      fail-fast: false
      matrix:
        environment:
<<- range .Helm.Environments >>
          - << . >>
<<- end >>
        production:
          - ${{ github.ref_name == github.event.repository.default_branch }}
        protected:
          - ${{ github.ref_name == github.event.repository.default_branch || github.ref_protected }}
        # see https://github.com/orgs/community/discussions/26253#discussioncomment-3250989
        # for more information about how to include environments depending on branches
        include:
<<- if has "review" .Helm.Environments >>
          - environment: review # enabled on non-protected branches
            protected: false
<<- end >>
<<- if has "integration" .Helm.Environments >>
          - environment: integration # enabled on protected branches
            protected: true
<<- end >>
<<- if has "staging" .Helm.Environments >>
          - environment: staging # enabled on production branches
            production: true
<<- end >>
<<- if has "production" .Helm.Environments >>
          - environment: production # enabled on production branches
            production: true
<<- end >>
    steps:
<<- if has "harden-runner" .GitHub.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@a5ad31d6a139d249332a2605b85202e8c0b78450 # v2.19.1
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      # https://github.com/marketplace/actions/helm-tool-installer
      - uses: azure/setup-helm@1a275c3b69536ee54be43f2070a358922e12c8d4 # v4.3.1
        with:
          # renovate: datasource=github-tags packageName=helm/helm depName=helm
          version: v4.1.4
      - shell: bash
        run: |-
          args=(--install --kube-context "$ENVIRONMENT" --version "$VERSION" -f "$HELM_CHART_DIR/values.yaml" --set "appVersion=$VERSION")
          [ -z "$HELM_ARGS" ] || args+=("$HELM_ARGS")
          [ -z "$HELM_DRY_RUN" ] || args+=("$HELM_DRY_RUN")

          name="$GITHUB_REPOSITORY_NAME-$VERSION"
          [ "$ENVIRONMENT" = "review" ] || name="$GITHUB_REPOSITORY_NAME"

          echo "Running helm upgrade with args '${args[@]}'"
          helm upgrade "${args[@]}" "$name" "${HELM_CHART_URL:-$HELM_CHART_DIR}"
        env:
          ENVIRONMENT: ${{ matrix.environment }}
          GITHUB_REPOSITORY_NAME: ${{ github.event.repository.name }}
          HELM_ARGS: ${{ vars.HELM_ARGS }}
          HELM_CHART_DIR: chart/
<<- if .HasHelmPublish >>
          HELM_CHART_URL: << $registry >>/<< $path >>
<<- end >>
          HELM_DRY_RUN: ${{ inputs.helm_deploy }}
          VERSION: ${{ needs.version.outputs.version }}
<<- end >>
<<- end >>
