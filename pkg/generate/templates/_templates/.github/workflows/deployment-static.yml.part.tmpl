jobs:
<<- define "static" >>

<<- $needs := list >>
<<- $websiteDirectory := .CI.Website.Directory | default "." >>

<<- $node := hasKey .Languages "node" >>
<<- if $node >><<- range (get .Languages "node") >><<- if eq .Directory $websiteDirectory >><<- $needs = append $needs "node-build" >><<- end >><<- end >><<- end >>

<<- $hugo := hasKey .Languages "hugo" >>
<<- if $hugo >><<- range (get .Languages "hugo") >><<- if eq .Directory $websiteDirectory >><<- $needs = append $needs "hugo-build" >><<- end >><<- end >><<- end >>

<<- if eq .CI.Website.Hosting "netlify" >>

  netlify:
    name: Netlify
    runs-on: ubuntu-latest
    if: ${{ inputs.netlify != 'none' }}
    needs:
<<- range $needs >>
      - << . >>
<<- end >>
    environment:
      name: netlify
      url: ${{ steps.netlify.outputs.deploy-url }}
    permissions:
      deployments: write
      pull-requests: write
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@df199fb7be9f65074067a9eb93f12bb4c5547cf2 # v2.13.3
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@8e8c483db84b4bee98b60c0593521ed34d9990e8 # v6.0.1
      - uses: actions/download-artifact@018cc2cf5baa6db3ef3c5f8a56943fffe632ef53 # v6
        with:
          name: build<< ne .CI.Website.Directory "" | ternary (print "-" .CI.Website.Directory) "" >>
          path: dist
      - id: branch_sha
        run: echo "branch_sha=$(echo "$GITHUB_REF_NAME" | sha256sum | cut -c -8)" >> $GITHUB_OUTPUT
      - id: config
        run: |-
          [ ! -f netlify.toml ] || echo "path=netlify.toml" >> $GITHUB_OUTPUT
      # https://github.com/marketplace/actions/netlify-actions
      - id: netlify
        uses: nwtgck/actions-netlify@4cbaf4c08f1a7bfa537d6113472ef4424e4eb654 # v3.0.0
        with:
          alias: ${{ steps.branch_sha.outputs.branch_sha }}
          deploy-message: ${{ github.ref_name }}
          enable-commit-comment: false
          enable-commit-status: false
          github-deployment-environment: netlify
          github-token: ${{ secrets.GITHUB_TOKEN }}
          netlify-config-path: ${{ steps.config.outputs.path }}
          production-branch: ${{ github.event.repository.default_branch }}
          publish-dir: dist
        env:
          NETLIFY_AUTH_TOKEN: ${{ secrets.NETLIFY_AUTH_TOKEN }}
          NETLIFY_SITE_ID: ${{ vars.NETLIFY_SITE_ID }}
<<- end >>

<<- if eq .CI.Website.Hosting "pages" >>

  pages:
    name: Pages
    runs-on: ubuntu-latest
    if: ${{ inputs.pages != 'none' }}
    needs:
<<- range $needs >>
      - << . >>
<<- end >>
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    permissions:
      id-token: write
      pages: write
      pull-requests: write
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@df199fb7be9f65074067a9eb93f12bb4c5547cf2 # v2.13.3
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - id: deployment
        uses: actions/deploy-pages@d6db90164ac5ed86f2b6aed7e0febac5b3c0c03e # v4.0.5
        with:
          artifact_name: build<< ne .CI.Website.Directory "" | ternary (print "-" .CI.Website.Directory) "" >>-pages
          preview: ${{ github.ref_name != github.event.repository.default_branch }}
<<- end >>
<<- end >>
