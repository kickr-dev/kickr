          fetch-depth: 0
<<- end >>
      - uses: actions/setup-python@e797f83bcb11b83ae66e0230d6156d7c80228e7c # v6.0.0
        with:
          # renovate: datasource=github-tags packageName=actions/python-versions
          python-version: 3.13.7
      - uses: pre-commit/action@2c7b3805fd2a0fd8c1884dcaebf91fc102a13ecd # v3.0.1
<<- if has "auto-commit" .PreCommit >>
      - if: ${{ !cancelled() }}
<<- if has "step-security-actions" .CI.Options >>
        # https://app.stepsecurity.io/github-action-advisor/step-security/git-auto-commit-action
        uses: step-security/git-auto-commit-action@e2d505468267a3cb406af729d48d664de1f16393 # v6.0.2
<<- else >>
        # https://github.com/marketplace/actions/git-auto-commit
        uses: stefanzweifel/git-auto-commit-action@28e16e81777b558cc906c8750092100bbb34c5e3 # v7
<<- end >>
        with:
          commit_message: "fix(commit): pre-commit autofixes [skip ci]"
<<- end >>
<<- end >>

<<- if $shell >>

  shellcheck:
