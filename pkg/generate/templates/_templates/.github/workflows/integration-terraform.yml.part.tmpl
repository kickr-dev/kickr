jobs:
<<- define "terraform" >>

<<- $engine := "opentofu" >>
<<- if and .Terraform .Terraform.Engine >><<- $engine = .Terraform.Engine >><<- end >>
<<- $cmd := eq $engine "opentofu" | ternary "tofu" "terraform" >>

<<- $nodes := get .Languages "terraform" >>

  << $engine >>-check:
    name: << title $engine >> Check ${{ matrix.name }}
    runs-on: ubuntu-latest
    needs: run-workflow
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .GitHub.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@a5ad31d6a139d249332a2605b85202e8c0b78450 # v2.19.1
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
<<- if eq $engine "terraform" >>
      - uses: hashicorp/setup-terraform@b9cd54a3c349d3f38e8881555d616ced269862dd # v3.1.2
        with:
          # renovate: datasource=github-tags packageName=hashicorp/terraform depName=terraform
          terraform_version: 1.15.2
<<- else >>
      - uses: opentofu/setup-opentofu@fc711fa910b93cba0f3fbecaafc9f42fd0c411cb # v2
        with:
          # renovate: datasource=github-tags packageName=opentofu/opentofu depName=opentofu
          tofu_version: 1.11.6
<<- end >>
      - run: << $cmd >> fmt -check
      - run: << $cmd >> init -backend=false
      - run: << $cmd >> validate -no-color

  << $engine >>-lint:
    name: << title $engine >> Lint
    runs-on: ubuntu-latest
    needs: run-workflow
    permissions:
      pull-requests: write
      security-events: write
    steps:
<<- if has "harden-runner" .GitHub.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@a5ad31d6a139d249332a2605b85202e8c0b78450 # v2.19.1
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: terraform-linters/setup-tflint@b480b8fcdaa6f2c577f8e4fa799e89e756bb7c93 # v6.2.2
        with:
          # renovate: datasource=github-tags packageName=terraform-linters/tflint depName=tflint
          tflint_version: v0.62.0
      - run: tflint --init
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
      - run: |-
          mkdir -p reports/
          tflint --config "$GITHUB_WORKSPACE/.tflint.hcl" --recursive --format sarif | tee reports/tflint.sarif
      - if: ${{ !cancelled() }}
        uses: github/codeql-action/upload-sarif@68bde559dea0fdcac2102bfdf6230c5f70eb485e # v4.35.4
        with:
          category: tflint
          sarif_file: reports/tflint.sarif

<<- if .HasTerraformApply >>
<<- range $node := $nodes >>

  << $engine >>-plan<< ne $node.Directory "." | ternary (print "-" (sha256sum $node.Directory | trunc 8)) "" >>:
    name: << title $engine >> Plan<< ne $node.Directory "." | ternary (printf " (%s)" $node.Directory) "" >>
    runs-on: ubuntu-latest
    needs: << $engine >>-check
    environment: ${{ matrix.environment }}
    strategy:
      fail-fast: false
      matrix:
        environment:
<<- range $.Terraform.Environments >>
          - << . >>
<<- end >>
<<- if ne $node.Directory "." >>
    defaults:
      run:
        working-directory: << $node.Directory >>
<<- end >>
    steps:
<<- if has "harden-runner" $.GitHub.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@a5ad31d6a139d249332a2605b85202e8c0b78450 # v2.19.1
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
<<- if eq $engine "terraform" >>
      - uses: hashicorp/setup-terraform@b9cd54a3c349d3f38e8881555d616ced269862dd # v3.1.2
        with:
          # renovate: datasource=github-tags packageName=hashicorp/terraform depName=terraform
          terraform_version: 1.15.2
<<- else >>
      - uses: opentofu/setup-opentofu@fc711fa910b93cba0f3fbecaafc9f42fd0c411cb # v2
        with:
          # renovate: datasource=github-tags packageName=opentofu/opentofu depName=opentofu
          tofu_version: 1.11.6
<<- end >>
      - run: |-
          << $cmd >> init
          << $cmd >> plan -no-color
<<- if or (gt (len $node.Specifics.Variables) 0) (eq $node.Specifics.Backend "s3") >>
        env:
<<- if eq $node.Specifics.Backend "s3" >>
          AWS_ACCESS_KEY: ${{ secrets.AWS_ACCESS_KEY }}
          AWS_SECRET_KEY: ${{ secrets.AWS_SECRET_KEY }}
<<- end >>
<<- range $name, $var := $node.Specifics.Variables >>
<<- $source := $var.Sensitive | ternary "secrets" "vars" >>
<<- if and (hasPrefix "github_" $name) (ne "github_token" $name) >>
          TF_VAR_<< $name >>: ${{ << print "github." (trimPrefix "github_" $name) >> }}
<<- else >>
          TF_VAR_<< $name >>: ${{ << print $source "." (upper $name) >> }}
<<- end >>
<<- end >>
<<- end >>
<<- end >>
<<- end >>
<<- end >>
