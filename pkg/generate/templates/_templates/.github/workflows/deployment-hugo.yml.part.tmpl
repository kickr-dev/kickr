jobs:
<<- define "hugo" >>
<<- $specifics := get .Languages "hugo" >>

  hugo-build:
    name: Hugo Build
    runs-on: ubuntu-latest
    needs: version
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@ec9f2d5744a09debf3a187a3f4f675c53b671911 # v2.13.0
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
        with:
          fetch-depth: 0 # fetch all history for .GitInfo and .Lastmod
          submodules: true # fetch Hugo themes (true OR recursive)
      - uses: actions/cache@0400d5f644dc74513175e3cd8d07132dd4860809 # v4.2.4
        with:
          path: /home/runner/.cache/hugo_cache
          key: hugo-${{ hashFiles('go.sum') }}
          restore-keys: |
            hugo-
<<- if has "harden-runner" .CI.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/actions-hugo
      - uses: step-security/actions-hugo@0ef63c546504c9fb32b29aa7eedc73d9558f7382 # v3.0.2
<<- else >>
      # https://github.com/marketplace/actions/hugo-setup
      - uses: peaceiris/actions-hugo@75d2e84710de30f6ff7268e08f310b60ef14033f # v3.0.0
<<- end >>
        with:
          hugo-version: latest
          extended: true
      - run: |-
<<- if $specifics.IsTheme >>
          [ ! -d exampleSite ] || cd exampleSite
<<- end >>
          hugo --gc --enableGitInfo --minify --destination "${GITHUB_WORKSPACE}/dist" --logLevel debug
        env:
          VERSION: ${{ needs.version.outputs.version }}
<<- if and .CI .CI.Pages >>
      - uses: actions/upload-pages-artifact@7b1f4a764d45c48632c6b24a0339c27f5614fb0b # v4.0.0
        with:
          name: github-pages
          path: dist
          retention-days: 1
<<- else >>
      - uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4.6.2
        with:
          name: build
          path: dist
          retention-days: 1
<<- end >>
<<- end >>
