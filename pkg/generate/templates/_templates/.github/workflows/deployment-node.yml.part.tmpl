jobs:
<<- define "node" >>

<<- $specifics := get .Languages "node" >>
<<- $manager := cutAfter $specifics.PackageManager "@" >>

  node-build:
    name: Node Build
    runs-on: ubuntu-latest
    needs: version
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@ec9f2d5744a09debf3a187a3f4f675c53b671911 # v2.13.0
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
<<- if eq $manager "pnpm" >>
      - uses: pnpm/action-setup@a7487c7e89a18df4991f7f222e4898a00d66ddda # v4.1.0
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "harden-runner" .CI.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@a961ff54612b97ac3259f517fb6a81be3b657a59 # v2.0.2
<<- else >>
      - uses: oven-sh/setup-bun@735343b667d3e6f658f44d0eca948eb6282f2b76 # v2.0.2
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      - uses: actions/setup-node@a0853c24544627f65ddf259abe73b1d18a591444 # v5
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
<<- if eq $manager "npm" >>
      - run: << $manager >> ci
<<- else >>
      - run: << $manager >> install --frozen-lockfile
<<- end >>
<<- if and .CI.Website .CI.Website.Directory >>
      - run: |-
          if [ ! -d "$DIRECTORY" ]; then
            echo "Provided directory '$DIRECTORY' doesn't exist"
            exit 2
          fi
          cd "$DIRECTORY"
          << $manager >> run build
        env:
          DIRECTORY: << .CI.Website.Directory >>
          VERSION: ${{ needs.version.outputs.version }}
<<- else >>
      - run: << $manager >> run build
        env:
          VERSION: ${{ needs.version.outputs.version }}
<<- end >>
<<- if .IsHosting "pages" >>
      - uses: actions/upload-pages-artifact@7b1f4a764d45c48632c6b24a0339c27f5614fb0b # v4.0.0
        with:
          name: github-pages
          path: dist
          retention-days: 1
<<- end >>
      - uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4.6.2
        with:
          name: build
          path: dist
          retention-days: 1
<<- end >>
