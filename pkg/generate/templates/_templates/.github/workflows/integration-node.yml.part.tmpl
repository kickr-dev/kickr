jobs:
<<- define "node" >>

<<- $nodes := get .Languages "node" >>
<<- $manager := cutAfter (first $nodes).Specifics.PackageManager "@" >>

  node-audit:
    name: Node Audit ${{ matrix.name }}
    runs-on: ubuntu-latest
    if: ${{ needs.run-workflow.outputs.skip == 'false' }}
    needs: run-workflow
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@f4a75cfd619ee5ce8d5b864b0d183aff3c69b55a # v2.13.1
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4.2.0
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .CI.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@81c6b5758214d7e8b68a403c6a55a040e9b8879a # v2.0.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@735343b667d3e6f658f44d0eca948eb6282f2b76 # v2.0.2
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@2028fbc5c25fe9cf00d9f06a71cc4710d4507903 # v6
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: << $manager >> audit
        continue-on-error: true

  node-lint:
    name: Node Lint ${{ matrix.name }}
    runs-on: ubuntu-latest
    if: ${{ needs.run-workflow.outputs.skip == 'false' }}
    needs: run-workflow
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - artifact: << ne .Directory "." | ternary (print "lint-" .Directory) "lint" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@f4a75cfd619ee5ce8d5b864b0d183aff3c69b55a # v2.13.1
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4.2.0
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .CI.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@81c6b5758214d7e8b68a403c6a55a040e9b8879a # v2.0.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@735343b667d3e6f658f44d0eca948eb6282f2b76 # v2.0.2
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@2028fbc5c25fe9cf00d9f06a71cc4710d4507903 # v6
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: |-
          mkdir -p reports/
          << $manager >> << eq $manager "npm" | ternary "ci" "install --frozen-lockfile" >>
          << $manager >> run lint -o reports/node-lint.xslint.json -f json
<<- if has "sonarqube" .CI.Options >>
      - uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4.6.2
        with:
          name: ${{ matrix.artifact }}
          path: ${{ matrix.directory }}/reports
          retention-days: 1
<<- end >>

  node-test:
    name: Node Test ${{ matrix.name }} (${{ matrix.os }})
    runs-on: ${{ matrix.os }}
    needs: node-lint
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: macos-latest
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: ubuntu-latest
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: windows-latest
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@f4a75cfd619ee5ce8d5b864b0d183aff3c69b55a # v2.13.1
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4.2.0
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .CI.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@81c6b5758214d7e8b68a403c6a55a040e9b8879a # v2.0.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@735343b667d3e6f658f44d0eca948eb6282f2b76 # v2.0.2
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@2028fbc5c25fe9cf00d9f06a71cc4710d4507903 # v6
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: |-
          mkdir -p reports/
          << $manager >> << eq $manager "npm" | ternary "ci" "install --frozen-lockfile" >>
<<- if eq $manager "bun" >>
          << $manager >> test --rerun-each 10 --coverage --coverage-reporter=lcov --coverage-dir=reports --reporter=junit --reporter-outfile="reports/node-test.xunit.xml"
<<- else >>
          << $manager >> run test -- --coverage --coverageDirectory=reports --reporters="jest-junit" --reporters="jest-sonar"
<<- end >>
<<- if has "codecov" .CI.Options >>
      - uses: codecov/test-results-action@47f89e9acb64b76debcd5ea40642d25a4adced9f # v1.1.1
        with:
          codecov_yml_path: .codecov.yml
          disable_search: true
          env_vars: OS
          fail_ci_if_error: false
          files: ${{ matrix.directory }}/reports/node-test.xunit.xml
          flags: ${{ matrix.os }}
          slug: ${{ matrix.name }}
          token: ${{ secrets.CODECOV_TOKEN }}
        env:
          OS: ${{ matrix.os }}
      - uses: codecov/codecov-action@5a1091511ad55cbe89839c7260b706298ca349f7 # v5.5.1
        with:
          codecov_yml_path: .codecov.yml
          disable_search: true
          env_vars: OS
          fail_ci_if_error: false
          files: ${{ matrix.directory }}/reports/lcov.info
          slug: ${{ matrix.name }}
          token: ${{ secrets.CODECOV_TOKEN }}
        env:
          OS: ${{ matrix.os }}
<<- end >>
<<- if has "sonarqube" .CI.Options >>
      - uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4.6.2
        with:
          name: ${{ matrix.artifact }}
          path: ${{ matrix.directory }}/reports
          retention-days: 1
<<- end >>
<<- end >>
