jobs:
<<- define "node" >>

<<- $nodes := get .Languages "node" >>
<<- $manager := cutAfter (first $nodes).Specifics.PackageManager "@" >>

  node-audit:
    name: Node Audit ${{ matrix.name }}
    runs-on: ubuntu-latest
    if: ${{ needs.run-workflow.outputs.skip == 'false' }}
    needs: run-workflow
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .GitHub.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@9af89fc71515a100421586dfdb3dc9c984fbf411 # v2.19.4
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@0ebf47130e4866e96fce0953f49152a61190b271 # v6.0.9
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .GitHub.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@f6f5dadeac34f70c7828f731569e8d6e8330b8fb # v2.1.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@0c5077e51419868618aeaa5fe8019c62421857d6 # v2.2.0
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@48b55a011bda9f5d6aeb4c2d9c7362e8dae4041e # v6.4.0
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: << $manager >> audit
        continue-on-error: true

  node-lint:
    name: Node Lint ${{ matrix.name }}
    runs-on: ubuntu-latest
    if: ${{ needs.run-workflow.outputs.skip == 'false' }}
    needs: run-workflow
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - artifact: << ne .Directory "." | ternary (print "lint-" .Directory) "lint" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .GitHub.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@9af89fc71515a100421586dfdb3dc9c984fbf411 # v2.19.4
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@0ebf47130e4866e96fce0953f49152a61190b271 # v6.0.9
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .GitHub.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@f6f5dadeac34f70c7828f731569e8d6e8330b8fb # v2.1.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@0c5077e51419868618aeaa5fe8019c62421857d6 # v2.2.0
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@48b55a011bda9f5d6aeb4c2d9c7362e8dae4041e # v6.4.0
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: |-
          mkdir -p reports/
          << $manager >> << eq $manager "npm" | ternary "ci" "install --frozen-lockfile" >>
          << $manager >> run lint -o reports/node-lint.xslint.json -f json
<<- if has "sonarqube" .GitHub.Options >>
      - uses: actions/upload-artifact@043fb46d1a93c77aae656e7c1c64a875d1fc6a0a # v7.0.1
        with:
          name: ${{ matrix.artifact }}
          path: ${{ matrix.directory }}/reports
          retention-days: 1
<<- end >>

  node-test:
    name: Node Test ${{ matrix.name }} (${{ matrix.os }})
    runs-on: ${{ matrix.os }}
    needs: node-lint
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: macos-latest
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: ubuntu-latest
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: windows-latest
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .GitHub.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@9af89fc71515a100421586dfdb3dc9c984fbf411 # v2.19.4
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@0ebf47130e4866e96fce0953f49152a61190b271 # v6.0.9
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .GitHub.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@f6f5dadeac34f70c7828f731569e8d6e8330b8fb # v2.1.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@0c5077e51419868618aeaa5fe8019c62421857d6 # v2.2.0
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@48b55a011bda9f5d6aeb4c2d9c7362e8dae4041e # v6.4.0
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: |-
          mkdir -p reports/
          << $manager >> << eq $manager "npm" | ternary "ci" "install --frozen-lockfile" >>
<<- if eq $manager "bun" >>
          << $manager >> test --rerun-each 10 --coverage --coverage-reporter=lcov --coverage-dir=reports --reporter=junit --reporter-outfile="reports/node-test.xunit.xml"
<<- else >>
          << $manager >> run test -- --coverage --coverageDirectory=reports --reporters="jest-junit" --reporters="jest-sonar"
<<- end >>
<<- if has "codecov" .GitHub.Options >>
      - uses: codecov/test-results-action@0fa95f0e1eeaafde2c782583b36b28ad0d8c77d3 # v1.2.1
        with:
          codecov_yml_path: .codecov.yml
          disable_search: true
          env_vars: OS
          fail_ci_if_error: false
          files: ${{ matrix.directory }}/reports/node-test.xunit.xml
          flags: ${{ matrix.os }}
          slug: ${{ matrix.name }}
          token: ${{ secrets.CODECOV_TOKEN }}
        env:
          OS: ${{ matrix.os }}
      - uses: codecov/codecov-action@fb8b3582c8e4def4969c97caa2f19720cb33a72f # v7
        with:
          codecov_yml_path: .codecov.yml
          disable_search: true
          env_vars: OS
          fail_ci_if_error: false
          files: ${{ matrix.directory }}/reports/lcov.info
          slug: ${{ matrix.name }}
          token: ${{ secrets.CODECOV_TOKEN }}
        env:
          OS: ${{ matrix.os }}
<<- end >>
<<- if has "sonarqube" .GitHub.Options >>
      - uses: actions/upload-artifact@043fb46d1a93c77aae656e7c1c64a875d1fc6a0a # v7.0.1
        with:
          name: ${{ matrix.artifact }}
          path: ${{ matrix.directory }}/reports
          retention-days: 1
<<- end >>
<<- end >>
