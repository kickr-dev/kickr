jobs:
<<- define "node" >>

<<- $nodes := get .Languages "node" >>
<<- $manager := cutAfter (first $nodes).Specifics.PackageManager "@" >>

  node-audit:
    name: Node Audit ${{ matrix.name }}
    runs-on: ubuntu-latest
    if: ${{ needs.run-workflow.outputs.skip == 'false' }}
    needs: run-workflow
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@20cf305ff2072d973412fa9b1e3a4f227bda3c76 # v2.14.0
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@8e8c483db84b4bee98b60c0593521ed34d9990e8 # v6.0.1
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4.2.0
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .CI.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@81c6b5758214d7e8b68a403c6a55a040e9b8879a # v2.0.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@b7a1c7ccf290d58743029c4f6903da283811b979 # v2.1.0
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@395ad3262231945c25e8478fd5baf05154b1d79f # v6.1.0
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: << $manager >> audit
        continue-on-error: true

  node-lint:
    name: Node Lint ${{ matrix.name }}
    runs-on: ubuntu-latest
    if: ${{ needs.run-workflow.outputs.skip == 'false' }}
    needs: run-workflow
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - artifact: << ne .Directory "." | ternary (print "lint-" .Directory) "lint" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@20cf305ff2072d973412fa9b1e3a4f227bda3c76 # v2.14.0
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@8e8c483db84b4bee98b60c0593521ed34d9990e8 # v6.0.1
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4.2.0
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .CI.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@81c6b5758214d7e8b68a403c6a55a040e9b8879a # v2.0.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@b7a1c7ccf290d58743029c4f6903da283811b979 # v2.1.0
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@395ad3262231945c25e8478fd5baf05154b1d79f # v6.1.0
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: |-
          mkdir -p reports/
          << $manager >> << eq $manager "npm" | ternary "ci" "install --frozen-lockfile" >>
          << $manager >> run lint -o reports/node-lint.xslint.json -f json
<<- if has "sonarqube" .CI.Options >>
      - uses: actions/upload-artifact@b7c566a772e6b6bfb58ed0dc250532a479d7789f # v6
        with:
          name: ${{ matrix.artifact }}
          path: ${{ matrix.directory }}/reports
          retention-days: 1
<<- end >>

  node-test:
    name: Node Test ${{ matrix.name }} (${{ matrix.os }})
    runs-on: ${{ matrix.os }}
    needs: node-lint
    strategy:
      fail-fast: false
      matrix:
        include:
<<- range $nodes >>
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: macos-latest
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: ubuntu-latest
          - artifact: << ne .Directory "." | ternary (print "coverage-" .Directory) "coverage" >>
            directory: << .Directory >>
<<- if ne .Directory "." >>
            name: << printf "(%s)" .Directory >>
<<- end >>
            os: windows-latest
<<- end >>
    defaults:
      run:
        working-directory: ${{ matrix.directory }}
    steps:
<<- if has "harden-runner" .CI.Options >>
      # https://docs.stepsecurity.io/harden-runner/workflow-runs
      # https://github.com/marketplace/actions/harden-runner
      - uses: step-security/harden-runner@20cf305ff2072d973412fa9b1e3a4f227bda3c76 # v2.14.0
        with:
          disable-sudo-and-containers: true
          egress-policy: audit
<<- end >>
      - uses: actions/checkout@8e8c483db84b4bee98b60c0593521ed34d9990e8 # v6.0.1
<<- if eq $manager "pnpm" >>
      # https://github.com/marketplace/actions/setup-pnpm
      - uses: pnpm/action-setup@41ff72655975bd51cab0327fa583b6e92b6d3061 # v4.2.0
<<- end >>
<<- if eq $manager "bun" >>
<<- if has "step-security-actions" .CI.Options >>
      # https://app.stepsecurity.io/github-action-advisor/step-security/setup-bun
      - uses: step-security/setup-bun@81c6b5758214d7e8b68a403c6a55a040e9b8879a # v2.0.3
<<- else >>
      # https://github.com/marketplace/actions/setup-bun
      - uses: oven-sh/setup-bun@b7a1c7ccf290d58743029c4f6903da283811b979 # v2.1.0
<<- end >>
        with:
          bun-version-file: package.json
<<- else >>
      # https://github.com/marketplace/actions/setup-node-js-environment
      - uses: actions/setup-node@395ad3262231945c25e8478fd5baf05154b1d79f # v6.1.0
        with:
          cache: << $manager >>
          node-version: lts/*
<<- end >>
      - run: |-
          mkdir -p reports/
          << $manager >> << eq $manager "npm" | ternary "ci" "install --frozen-lockfile" >>
<<- if eq $manager "bun" >>
          << $manager >> test --rerun-each 10 --coverage --coverage-reporter=lcov --coverage-dir=reports --reporter=junit --reporter-outfile="reports/node-test.xunit.xml"
<<- else >>
          << $manager >> run test -- --coverage --coverageDirectory=reports --reporters="jest-junit" --reporters="jest-sonar"
<<- end >>
<<- if has "codecov" .CI.Options >>
      - uses: codecov/test-results-action@0fa95f0e1eeaafde2c782583b36b28ad0d8c77d3 # v1.2.1
        with:
          codecov_yml_path: .codecov.yml
          disable_search: true
          env_vars: OS
          fail_ci_if_error: false
          files: ${{ matrix.directory }}/reports/node-test.xunit.xml
          flags: ${{ matrix.os }}
          slug: ${{ matrix.name }}
          token: ${{ secrets.CODECOV_TOKEN }}
        env:
          OS: ${{ matrix.os }}
      - uses: codecov/codecov-action@671740ac38dd9b0130fbe1cec585b89eea48d3de # v5.5.2
        with:
          codecov_yml_path: .codecov.yml
          disable_search: true
          env_vars: OS
          fail_ci_if_error: false
          files: ${{ matrix.directory }}/reports/lcov.info
          slug: ${{ matrix.name }}
          token: ${{ secrets.CODECOV_TOKEN }}
        env:
          OS: ${{ matrix.os }}
<<- end >>
<<- if has "sonarqube" .CI.Options >>
      - uses: actions/upload-artifact@b7c566a772e6b6bfb58ed0dc250532a479d7789f # v6
        with:
          name: ${{ matrix.artifact }}
          path: ${{ matrix.directory }}/reports
          retention-days: 1
<<- end >>
<<- end >>
