{{- $start := 7 }}

diff --git a/.gitignore b/.gitignore
index 332d5ce..39af8aa 100644
--- a/.gitignore
+++ b/.gitignore
@@ -1,0 +1,{{ $start }} @@
+# Code generated by kickr; DO NOT EDIT.
+
+# Various build / compile directories
+dist/
+reports/
+
+
\ No newline at end of file

{{- if hasKey .Languages "node" }}
{{- $nodes := get .Languages "node" }}
{{- $manager := cutAfter (first $nodes).Specifics.PackageManager "@" }}
{{- if eq $manager "bun" }}

diff --git a/.gitignore b/.gitignore
index 11bb2a7..d601cbd 100644
--- a/.gitignore
+++ b/.gitignore
@@ -64,2 +65,3 @@
 # Optional npm cache directory
+.bun
 .npm

\ No newline at end of file
{{- end }}
{{- end }}

{{- if .IsHosting "netlify" }}

diff --git a/.gitignore b/.gitignore
index 332d5ce..39af8aa 100644
--- a/.gitignore
+++ b/.gitignore
@@ -{{ $start }},0 +{{ $start }},4 @@
+# Local Netlify folder
+.netlify
+
+
\ No newline at end of file
{{- $start = add $start 4 }}
{{- end }}

{{- $lines := list }}
{{- if hasKey .Languages "go" }}

{{- range $name, $config := .Clis }}
{{- $lines = append $lines $name }}
{{- $lines = append $lines (printf "!%s/" $name) }}
{{- end }}

{{- if gt (len .Crons) 0 }}
{{- $lines = append $lines "cron-*" }}
{{- $lines = append $lines "!cron-*/" }}
{{- end }}

{{- if gt (len .Jobs) 0 }}
{{- $lines = append $lines "job-*" }}
{{- $lines = append $lines "!job-*/" }}
{{- end }}

{{- if gt (len .Workers) 0 }}
{{- $lines = append $lines "worker-*" }}
{{- $lines = append $lines "!worker-*/" }}
{{- end }}

{{- end }}

{{- if gt (len $lines) 0 }}

diff --git a/.gitignore b/.gitignore
index 332d5ce..39af8aa 100644
--- a/.gitignore
+++ b/.gitignore
@@ -{{ $start }},0 +{{ $start }},{{ add (len $lines) 2 }} @@
+# Binaries for programs
{{- range $lines }}
+{{ . }}
{{- end }}
+
+
\ No newline at end of file
{{- $start = add $start (add (len $lines) 2) }}
{{- end }}
