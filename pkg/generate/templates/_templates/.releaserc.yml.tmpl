# Code generated by kickr; DO NOT EDIT.

# https://semantic-release.gitbook.io/semantic-release/usage/configuration

{{- $golang := hasKey .Languages "go" }}
{{- $gobuild := and $golang (gt .Binaries 0) }}

{{- $hugo := hasKey .Languages "hugo" }}
{{- $node := hasKey .Languages "node" }}

branches:
  - (main|master)
  - v+([0-9])?(.{+([0-9]),x}).x
  - name: (alpha|beta|next|rc)
    prerelease: true
  - name: staging
    prerelease: beta
  - name: dev*([a-z])
    prerelease: alpha

tagFormat: v${version}

plugins:
  - - "@semantic-release/commit-analyzer"
    - preset: conventionalcommits
      presetConfig:
        types:
          - { type: feat, section: "Features" }
          - { type: fix, section: "Bug Fixes" }
          - { type: revert, section: "Reverts" }
          - { type: perf, section: "Performance Improvements" }
          - { type: docs, section: "Documentation" }
          - { type: chore, section: "Chores" }
          - { type: refactor, section: "Code Refactoring" }

          - { type: build, section: "Build System" }
          - { type: ci, section: "Continuous Integration" }
          - { type: style, section: "Styles" }
          - { type: test, section: "Tests" }
      releaseRules:
        - { breaking: true, release: major }
        - { revert: true, release: patch }
        - { type: feat, release: minor }
        - { type: fix, release: patch }
        - { type: revert, release: patch }
        - { type: perf, release: patch }
        - { type: docs, release: patch }
        - { type: chore, release: patch }
        - { type: refactor, release: minor }

        - { scope: release, release: false }
      parserOpts:
        noteKeywords:
          - BREAKING CHANGE
          - BREAKING CHANGES
          - BREAKING
  - - "@semantic-release/release-notes-generator"
    - preset: conventionalcommits
      presetConfig:
        types:
          - { type: feat, section: "Features" }
          - { type: fix, section: "Bug Fixes" }
          - { type: revert, section: "Reverts" }
          - { type: perf, section: "Performance Improvements" }
          - { type: docs, section: "Documentation" }
          - { type: chore, section: "Chores" }
          - { type: refactor, section: "Code Refactoring" }

          - { type: build, section: "Build System" }
          - { type: ci, section: "Continuous Integration" }
          - { type: style, section: "Styles" }
          - { type: test, section: "Tests" }
      parserOpts:
        noteKeywords:
        - BREAKING CHANGE
        - BREAKING CHANGES
        - BREAKING
  - "@semantic-release/changelog"
{{- if and .License (list "bsl-1.0" "mit" | has .License) }}
  - "semantic-release-license"
{{- end }}
{{- if $node }}
  - "@semantic-release/npm"
{{- end }}
  - - "@semantic-release/git"
    - assets:
        - CHANGELOG.md
{{- if and .License (list "bsl-1.0" "mit" | has .License) }}
        - LICENSE
{{- end }}
{{- if $node }}
        - package.json
{{- end }}
      message: "chore(release): v${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
{{- if eq .VCS.Platform "github" }}
  - - "@semantic-release/github"
    - draftRelease: false
      failComment: ⚠️ Expected release for branch '${branch.name}' has failed due to the following errors:\n- ${errors.map(err => err.message).join('\\n- ')}
      failCommentCondition: <% return false; %>
      successComment: 🎉 This issue has been resolved in version v${nextRelease.version} 🎉
      successCommentCondition: <% return true; %>
      assets:
        - path: ./CHANGELOG.md
{{- if $gobuild }}
        - path: dist/checksums.txt
        - path: dist/*.deb
        - path: dist/*.rpm
        - path: dist/*.tar.gz
        - path: dist/*.zip
{{- end }}
{{- end }}
{{- if eq .VCS.Platform "gitlab" }}
  - - "@semantic-release/gitlab"
    - failComment: ⚠️ Expected release for branch '${branch.name}' has failed due to the following errors:\n- ${errors.map(err => err.message).join('\\n- ')}
      failCommentCondition: <% return false; %>
      successComment: 🎉 This issue has been resolved in version v${nextRelease.version} 🎉
      successCommentCondition: <% return true; %>
      assets:
        - path: ./CHANGELOG.md
{{- if $gobuild }}
        - path: dist/checksums.txt
        - path: dist/*.deb
        - path: dist/*.rpm
        - path: dist/*.tar.gz
        - path: dist/*.zip
{{- end }}
{{- end }}
{{- if has "backmerge" .CI.Release.Options }}
  - - "@kilianpaquier/semantic-release-backmerge"
    - targets:
        - from: ^(main|master)$
          to: staging
        - from: ^(main|master)$
          to: ^(dev|develop)$
        - from: staging
          to: ^(dev|develop)$
{{- if ne .CI.Provider .Platform }}
      platform: {{ .Platform }}
{{- end }}
{{- end }}
{{- if eq .CI.Provider "gitlab" }}
  - - "@semantic-release/exec"
    - analyzeCommitsCmd: echo "SEMREL_INFO_LAST_VERSION=${lastRelease.version}" > semrel.out.env
      verifyReleaseCmd: |
        echo "SEMREL_INFO_NEXT_VERSION=${nextRelease.version}" >> semrel.out.env
        echo "SEMREL_INFO_NEXT_VERSION_TYPE=${nextRelease.type}" >> semrel.out.env
{{- end }}
