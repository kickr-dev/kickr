{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",

    "ignorePaths": [
        "**/testdata/**"
    ],

    "packageRules": [
        {
            "matchFileNames": [ "/.*\\.tmpl$/" ],
            "postUpgradeTasks": {
                "commands": [ "./scripts/sh/renovate.sh" ],
                "executionMode": "branch"
            }
        }
    ]
}
