{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",

    "github-actions": {
        "enabled": false // project's Actions are maintained by templates updates
    },

    "packageRules": [
        {
            "matchFileNames": [ "/.*\\.tmpl$/" ],
            "postUpgradeTasks": {
                "commands": [ "./scripts/sh/renovate.sh" ],
                "executionMode": "branch"
            }
        }
    ]
}
